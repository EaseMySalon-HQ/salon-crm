# Server Configuration
PORT=3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration (for future use)
DATABASE_URL=your-database-url

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
# Logging: error | warn | info | debug (production default is warn via code if unset)
LOG_LEVEL=warn
# Log MongoDB commands slower than this (ms); requires monitorCommands (enabled in app)
SLOW_QUERY_MS=300

# Email Service Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
# API key starts with 're_' (e.g., re_xxxxxxxxxxxxx)
EMAIL_API_KEY=your-resend-api-key-here
EMAIL_FROM=noreply@easemysalon.in
EMAIL_FROM_NAME=EaseMySalon
EMAIL_REPLY_TO=support@easemysalon.in

# Platform admin: email when a new unassigned lead is added (requires EMAIL_API_KEY or Admin email settings)
# PLATFORM_LEAD_NOTIFY_ENABLED=false
# PLATFORM_LEAD_NOTIFY_EMAILS=ops@example.com,sales@example.com
# ADMIN_FRONTEND_URL=https://your-app.example.com

# SMS (MSG91) – optional; can also be set in Admin Settings → Notifications → SMS
# Get auth key from https://control.msg91.com/ and create templates (Flow API v5)
MSG91_SMS_AUTH_KEY=
# Optional default template IDs (otherwise configure in admin UI):
# MSG91_SMS_TEMPLATE_RECEIPT=
# MSG91_SMS_TEMPLATE_APPOINTMENT_CONFIRMATION=
# MSG91_SMS_TEMPLATE_APPOINTMENT_CANCELLATION=
# MSG91_SMS_TEMPLATE_TEST=

# ---------------------------------------------------------------------------
# WhatsApp — Gupshup (primary) + MSG91 (legacy fallback)
# ---------------------------------------------------------------------------
# Gupshup Partner Portal (https://partner.gupshup.io).
# See .cursor/rules/gupshup-partner-integration.mdc for the full contract.
# GUPSHUP_PARTNER_BASE_URL=https://partner.gupshup.io
# GUPSHUP_EMAIL=partner-account@example.com
# GUPSHUP_CLIENT_SECRET=            # login secret (Portal -> Settings -> API client details)
# Or save partner email/secret in Admin → API & Integration → Gupshup (encrypted in DB).
#
# Shared platform Gupshup app — fallback sender for salons without their own app.
# GUPSHUP_PLATFORM_APP_ID=
# GUPSHUP_PLATFORM_APP_NAME=
# GUPSHUP_PLATFORM_SOURCE_NUMBER=   # business number, country-code prefixed, no '+'
#
# Inbound webhook auth — verify BOTH the shared-secret header AND the source IP.
# GUPSHUP_WEBHOOK_SECRET=           # mirrored into the subscription `meta` headers
# GUPSHUP_WEBHOOK_IPS=34.202.224.208,52.66.99.126,15.206.217.7,13.126.35.181,3.6.228.131,13.232.173.180,13.127.57.130,13.234.143.231,3.7.115.196,13.232.49.3,18.193.1.225,3.68.131.220,63.176.209.228,63.183.31.123
#
# Public webhook URL for Gupshup delivery callbacks (full URL, highest priority).
# If unset, built from BACKEND_PUBLIC_URL + /api/webhooks/whatsapp/gupshup, or
# auto-detected (Railway RAILWAY_PUBLIC_DOMAIN, localhost in dev). You can also
# set the URL in Admin → API & Integration → Gupshup.
# GUPSHUP_WEBHOOK_URL=https://your-backend.example.com/api/webhooks/whatsapp/gupshup
# BACKEND_PUBLIC_URL=https://your-backend.example.com
#
# Gupshup app access tokens are encrypted at rest with WHATSAPP_TOKEN_ENC_KEY.

# ---------------------------------------------------------------------------
# Redis (API cache, shared rate limits, BullMQ campaign workers)
# ---------------------------------------------------------------------------
# The app reads REDIS_URL first, then RATE_LIMIT_REDIS_URL. Fail-open if unset.
#
# Local dev:
#   docker compose -f docker-compose.redis.yml up -d
#   REDIS_URL=redis://127.0.0.1:6379
#   node scripts/verify-redis.js
#
# Railway staging/production:
#   1. In the Railway project: New → Database → Redis (or add Redis plugin).
#   2. Open your **backend** service → Variables.
#   3. Add a reference variable (recommended name: REDIS_URL):
#        ${{Redis.REDIS_URL}}
#      (Pick the Redis service from the dropdown — Railway injects the URL.)
#   4. Redeploy the backend. Optional: add a second service for workers with the
#      same REDIS_URL and start command `npm run worker:whatsapp-campaigns`.
#   5. Verify: curl https://<backend-host>/health
#      → services.redis should be "ok" (not "disabled" or "degraded").
#
# Railway often uses redis:// or rediss:// with password — both work with ioredis.
# If ping fails but the variable is set, use the **private** URL from the Redis
# service (Variables tab) when API and Redis are in the same project.
#
# REDIS_URL=redis://127.0.0.1:6379
# RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379
# MONGO_MAIN_POOL_SIZE=50
# MONGO_TENANT_POOL_SIZE=10
# MONGO_MAX_CACHED_TENANTS=50
# MONGO_MAX_IDLE_MS=120000
# MONGO_HEARTBEAT_MS=10000
# MONGO_HEALTH_PING_INTERVAL_MS=5000
# DASHBOARD_REDIS_TTL_SEC=60
# PLAN_REDIS_TTL_SEC=1800
# LIST_REDIS_TTL_SEC=120
# APPOINTMENTS_REDIS_TTL_SEC=45
# DAILY_ROWS_DEDUP_MS=30000

# WhatsApp Meta campaigns (BullMQ — requires REDIS_URL + separate worker process)
# WHATSAPP_CAMPAIGN_MAX_RECIPIENTS=10000
# WHATSAPP_CAMPAIGN_WORKER_INLINE=0
# npm run worker:whatsapp-campaigns

# Legacy MSG91 campaigns (/api/campaigns)
# LEGACY_CAMPAIGN_INPROCESS_MAX=500
# LEGACY_CAMPAIGN_MAX_RECIPIENTS=10000
# LEGACY_CAMPAIGN_WORKER_INLINE=0
# npm run worker:legacy-campaigns