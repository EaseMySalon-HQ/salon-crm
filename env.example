# API Configuration
# Tenant cookie auth: use same-origin /api + proxy so session cookies bind to this host (required on mobile when API is another origin).
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://localhost:3001

# Without proxy (direct cross-origin API — may break on iPad Chrome):
# NEXT_PUBLIC_API_URL=http://localhost:3001/api
# (omit API_PROXY_TARGET)

# Development Settings
NEXT_PUBLIC_ENVIRONMENT=development

# Performance Logging (backend)
# Logs per-request method/path/status/duration/byte-size for spotting noisy endpoints.
# Auto-enabled in development; flip to "true" to enable in staging/production.
# Never logs cookies, tokens, request bodies, or customer PII.
# ENABLE_PERF_LOGS=true

# Site URL for SEO (canonical URLs, structured data, sitemap)
# Update this with your production URL when deploying
NEXT_PUBLIC_SITE_URL=https://www.easemysalon.in 